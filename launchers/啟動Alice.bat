@echo off
:: 切換命令提示字元編碼為 UTF-8
chcp 65001 >nul

title Alice 秘書系統 v3.2
color 0A

echo =================================================
echo        正在喚醒 Alice，請稍候...
echo =================================================
echo.

:: 確保當前目錄是正確的 (切換到這隻 bat 檔案所在的資料夾)
cd /d "%~dp0.."

:: ── 環境檢查 ──
echo [1/2] 執行環境檢查...
python legacy\setup_check.py
if %ERRORLEVEL% NEQ 0 (
    echo.
    echo =================================================
    echo  環境檢查失敗！請修正後再試。
    echo  若為首次在新電腦使用，請執行「隨身硬碟首次啟動.bat」
    echo =================================================
    pause
    exit /b 1
)

echo.
echo [2/2] 環境就緒，啟動 Alice 主程式...
echo.

:: 啟動機器人
python legacy\main.py

:: 如果程式崩潰或關閉，暫停畫面讓您看得到錯誤訊息
echo.
echo =================================================
echo        Alice 已停止運作。
echo =================================================
pause
